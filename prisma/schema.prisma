enum PeriodType {
  HELAAR
  H1
  H2
  Q1
  Q2
  Q3
  Q4
  MAANED
}

enum MetricSource {
  REVIDERET
  UREVIDERET
  ESTIMAT
}

enum TpMethod {
  CUP
  COST_PLUS
  TNMM

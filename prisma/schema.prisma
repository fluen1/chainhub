}

// ==================== CORE TABLES ====================

model Organization {
  id              String    @id @default(uuid())
  name            String
  cvr             String?
  plan            String    @default("trial") // trial | starter | business | enterprise
  planExpiresAt   DateTime? @map("plan_expires_at")
  chainStructure  Boolean   @default(false) @map("chain_structure")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdBy       String?   @map("created_by") // DEC-019: NULL ved self-signup

  // Relations
  users               User[]
  companies           Company[]
  persons             Person[]
  contracts           Contract[]
  cases               Case[]
  tasks               Task[]
  documents           Document[]
  userRoleAssignments UserRoleAssignment[]
  financialMetrics    FinancialMetric[] // DEC-019
  timeEntries         TimeEntry[] // DEC-019
  subscription        Subscription?
  deadlines           Deadline[]
  reminders           Reminder[]

  @@index([id])
  @@map("organizations")
}

model User {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  email          String
  name           String
  avatarUrl      String?   @map("avatar_url")
  microsoftId    String?   @map("microsoft_id") // Azure AD object ID
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  organization     Organization         @relation(fields: [organizationId], references: [id])
  roles            UserRoleAssignment[]
  createdContracts Contract[]           @relation("ContractCreatedBy")
  assignedTasks    Task[]               @relation("TaskAssignedTo")

  @@unique([organizationId, email])
  @@index([organizationId, deletedAt])
  @@map("users")
}

model UserRoleAssignment {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  userId         String    @map("user_id")
  role           UserRole
  scope          UserScope
  companyIds     String[]  @map("company_ids") // kun relevant ved scope = ASSIGNED
  createdAt      DateTime  @default(now()) @map("created_at")
  createdBy      String    @map("created_by")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, userId])
  @@map("user_role_assignments")
}

// ==================== COMPANY & OWNERSHIP ====================

model Company {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  name           String
  cvr            String?
  companyType    String?   @map("company_type") // ApS, A/S, I/S, enkeltmandsvirksomhed
  address        String?
  city           String?
  postalCode     String?   @map("postal_code")
  foundedDate    DateTime? @map("founded_date")
  status         String    @default("aktiv") // aktiv | inaktiv | under_stiftelse | opløst
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      String    @map("created_by")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  organization    Organization     @relation(fields: [organizationId], references: [id])
  ownerships      Ownership[]
  companyPersons  CompanyPerson[]
  contracts       Contract[]
  caseCompanies   CaseCompany[]
  documents       Document[]
  financialMetrics FinancialMetric[]

  // Sprint 5: Compound indexes for dashboard-query performance
  // Dashboard henter selskaber per organisation — organization_id + deleted_at bruges altid
  @@index([organizationId, deletedAt])
  // Status-filter bruges i dashboard og company-liste
  @@index([organizationId, status])
  // Sprint 5: Dashboard compound index — status + deleted_at kombineret
  @@index([organizationId, status, deletedAt])
  @@map("companies")
}

model Ownership {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  companyId      String    @map("company_id")
  ownerPersonId  String?   @map("owner_person_id")
  ownerCompanyId String?   @map("owner_company_id")
  ownershipPct   Decimal   @map("ownership_pct") @db.Decimal(5, 2)
  shareClass     String?   @map("share_class")
  effectiveDate  DateTime? @map("effective_date")
  contractId     String?   @map("contract_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  createdBy      String    @map("created_by")

  // Relations
  company     Company   @relation(fields: [companyId], references: [id])
  ownerPerson Person?   @relation(fields: [ownerPersonId], references: [id])
  contract    Contract? @relation(fields: [contractId], references: [id])

  @@index([organizationId, companyId])
  @@map("ownerships")
}

// ==================== PERSONS ====================

model Person {
  id                 String    @id @default(uuid())
  organizationId     String    @map("organization_id")
  firstName          String    @map("first_name")
  lastName           String    @map("last_name")
  email              String?
  phone              String?
  notes              String?
  microsoftContactId String?   @map("microsoft_contact_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  createdBy          String    @map("created_by")
  deletedAt          DateTime? @map("deleted_at")

  // Relations
  organization    Organization    @relation(fields: [organizationId], references: [id])
  companyPersons  CompanyPerson[]
  contractParties ContractParty[]
  ownerships      Ownership[]
  casePersons     CasePerson[]

  @@index([organizationId, deletedAt])
  @@map("persons")
}

model CompanyPerson {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  companyId       String    @map("company_id")
  personId        String    @map("person_id")
  role            String    // direktør | bestyrelsesmedlem | ansat | revisor
  employmentType  String?   @map("employment_type") // funktionær | ikke-funktionær | vikar | elev
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  anciennityStart DateTime? @map("anciennity_start")
  contractId      String?   @map("contract_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  createdBy       String    @map("created_by")

  // Relations
  company  Company   @relation(fields: [companyId], references: [id])
  person   Person    @relation(fields: [personId], references: [id])
  contract Contract? @relation(fields: [contractId], references: [id])

  @@index([organizationId, companyId])
  @@index([organizationId, personId])
  @@map("company_persons")
}

// ==================== CONTRACTS ====================

model Contract {
  id                  String             @id @default(uuid())
  organizationId      String             @map("organization_id")
  companyId           String             @map("company_id")
  systemType          ContractSystemType @map("system_type")
  displayName         String             @map("display_name")
  status              ContractStatus     @default(UDKAST)
  sensitivity         SensitivityLevel   @default(STANDARD)
  deadlineType        DeadlineType       @default(INGEN) @map("deadline_type")
  versionSource       VersionSource      @default(CUSTOM) @map("version_source")
  collectiveAgreement String?            @map("collective_agreement")
  parentContractId    String?            @map("parent_contract_id")
  triggeredById       String?            @map("triggered_by_id")

  // Dates
  effectiveDate     DateTime? @map("effective_date")
  expiryDate        DateTime? @map("expiry_date")
  signedDate        DateTime? @map("signed_date")
  noticePeriodDays  Int?      @map("notice_period_days")
  terminationDate   DateTime? @map("termination_date")
  anciennityStart   DateTime? @map("anciennity_start")

  // Reminders
  reminder90Days      Boolean  @default(true) @map("reminder_90_days")
  reminder30Days      Boolean  @default(true) @map("reminder_30_days")
  reminder7Days       Boolean  @default(true) @map("reminder_7_days")
  reminderRecipients  String[] @map("reminder_recipients")

  // Retention
  mustRetainUntil DateTime? @map("must_retain_until")

  // Type-specific data (JSONB)
  typeData Json? @map("type_data")

  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdBy    String    @map("created_by")
  lastViewedAt DateTime? @map("last_viewed_at")
  lastViewedBy String?   @map("last_viewed_by")
  deletedAt    DateTime? @map("deleted_at")

  // Relations
  organization    Organization         @relation(fields: [organizationId], references: [id])
  company         Company              @relation(fields: [companyId], references: [id])
  parentContract  Contract?            @relation("ContractHierarchy", fields: [parentContractId], references: [id])
  childContracts  Contract[]           @relation("ContractHierarchy")
  createdByUser   User                 @relation("ContractCreatedBy", fields: [createdBy], references: [id])
  parties         ContractParty[]
  versions        ContractVersion[]
  attachments     ContractAttachment[]
  relationsFrom   ContractRelation[]   @relation("RelationFrom")
  relationsTo     ContractRelation[]   @relation("RelationTo")
  caseContracts   CaseContract[]
  ownerships      Ownership[]
  companyPersons  CompanyPerson[]
  reminders       Reminder[]
  deadlines       Deadline[]

  // Eksisterende indexes
  @@index([organizationId, deletedAt])
  @@index([organizationId, companyId, deletedAt])
  @@index([organizationId, systemType, deletedAt])
  @@index([organizationId, status, deletedAt])
  @@index([expiryDate])
  // Sprint 5: Dashboard bruger expiry_date range + status + organization_id
  // Understøtter "kontrakter der udløber inden 30 dage"-query i dashboard
  @@index([organizationId, status, expiryDate])
  @@map("contracts")
}

model ContractParty {
  id               String   @id @default(uuid())
  organizationId   String   @map("organization_id")
  contractId       String   @map("contract_id")
  personId         String?  @map("person_id")
  isSigner         Boolean  @default(false) @map("is_signer")
  counterpartyName String?  @map("counterparty_name")
  roleInContract   String?  @map("role_in_contract")
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  contract Contract @relation(fields: [contractId], references: [id])
  person   Person?  @relation(fields: [personId], references: [id])

  @@index([organizationId, contractId])
  @@map("contract_parties")
}

model ContractVersion {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  contractId     String     @map("contract_id")
  versionNumber  Int        @map("version_number")
  fileUrl        String     @map("file_url")
  fileName       String     @map("file_name")
  fileSizeBytes  Int        @map("file_size_bytes")
  isCurrent      Boolean    @default(false) @map("is_current")
  changeType     ChangeType @default(REDAKTIONEL) @map("change_type") // DEC-002/013
  changeNote     String?    @map("change_note")
  amendsClause   String?    @map("amends_clause") // DEC-002/013
  uploadedAt     DateTime   @default(now()) @map("uploaded_at")
  uploadedBy     String     @map("uploaded_by")

  // Relations
  contract Contract @relation(fields: [contractId], references: [id])

  @@index([organizationId, contractId])
  @@map("contract_versions")
}

model ContractAttachment {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  contractId     String    @map("contract_id")
  fileUrl        String    @map("file_url")
  fileName       String    @map("file_name")
  fileSizeBytes  Int       @map("file_size_bytes")
  description    String?
  uploadedAt     DateTime  @default(now()) @map("uploaded_at")
  uploadedBy     String    @map("uploaded_by")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  contract Contract @relation(fields: [contractId], references: [id])

  @@index([organizationId, contractId])
  @@map("contract_attachments")
}

model ContractRelation {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  fromContractId String       @map("from_contract_id")
  toContractId   String       @map("to_contract_id")
  relationType   RelationType @map("relation_type")
  createdAt      DateTime     @default(now()) @map("created_at")
  createdBy      String       @map("created_by")

  // Relations
  fromContract Contract @relation("RelationFrom", fields: [fromContractId], references: [id])
  toContract   Contract @relation("RelationTo", fields: [toContractId], references: [id])

  @@unique([fromContractId, toContractId, relationType])
  @@index([organizationId, fromContractId])
  @@index([organizationId, toContractId])
  @@map("contract_relations")
}

// ==================== CASES & TASKS ====================

model Case {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  title          String
  caseType       SagsType         @map("case_type")
  caseSubtype    SagsSubtype?     @map("case_subtype")
  status         CaseStatus       @default(NY)
  sensitivity    SensitivityLevel @default(INTERN)
  description    String?
  responsibleId  String?          @map("responsible_id")
  dueDate        DateTime?        @map("due_date")
  closedAt       DateTime?        @map("closed_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  createdBy      String           @map("created_by")
  deletedAt      DateTime?        @map("deleted_at")

  // Relations
  organization  Organization   @relation(fields: [organizationId], references: [id])
  caseCompanies CaseCompany[]
  caseContracts CaseContract[]
  casePersons   CasePerson[]
  tasks         Task[]
  documents     Document[]
  timeEntries   TimeEntry[]
  deadlines     Deadline[]

  @@index([organizationId, deletedAt])
  @@index([organizationId, status, deletedAt])
  // Sprint 5: Dashboard "åbne sager" query bruger status IN (...) — eksisterende index dækker dette
  @@map("cases")
}

// DEC-016: organization_id, created_at, created_by tilføjet
model CaseCompany {
  organizationId String   @map("organization_id")
  caseId         String   @map("case_id")
  companyId      String   @map("company_id")
  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      String   @map("created_by")

  // Relations
  case    Case    @relation(fields: [caseId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@id([caseId, companyId])
  @@index([organizationId, caseId])
  // Sprint 5: Dashboard JOIN på company_id for case-counts per selskab
  @@index([organizationId, companyId])
  @@map("case_companies")
}

// DEC-016: organization_id, created_at, created_by tilføjet
model CaseContract {
  organizationId String   @map("organization_id")
  caseId         String   @map("case_id")
  contractId     String   @map("contract_id")
  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      String   @map("created_by")

  // Relations
  case     Case     @relation(fields: [caseId], references: [id])
  contract Contract @relation(fields: [contractId], references: [id])

  @@id([caseId, contractId])
  @@index([organizationId, caseId])
  @@map("case_contracts")
}

// DEC-016: organization_id, created_at, created_by tilføjet
model CasePerson {
  organizationId String   @map("organization_id")
  caseId         String   @map("case_id")
  personId       String   @map("person_id")
  role           String?
  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      String   @map("created_by")

  // Relations
  case   Case   @relation(fields: [caseId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@id([caseId, personId])
  @@index([organizationId, caseId])
  @@map("case_persons")
}

model Task {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  title          String
  description    String?
  status         TaskStatus @default(NY)
  dueDate        DateTime?  @map("due_date")
  assignedTo     String?    @map("assigned_to")
  caseId         String?    @map("case_id")
  companyId      String?    @map("company_id")
  contractId     String?    @map("contract_id")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  createdBy      String     @map("created_by")
  deletedAt      DateTime?  @map("deleted_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  assignee     User?        @relation("TaskAssignedTo", fields: [assignedTo], references: [id])
  case         Case?        @relation(fields: [caseId], references: [id])

  @@index([organizationId, deletedAt])
  @@index([organizationId, assignedTo, deletedAt])
  @@index([organizationId, dueDate])
  // Sprint 5: Dashboard task-count per selskab — company_id + organization_id + deleted_at
  @@index([organizationId, companyId, deletedAt])
  @@map("tasks")
}

model Deadline {
  id               String    @id @default(uuid())
  organizationId   String    @map("organization_id")
  title            String
  dueDate          DateTime  @map("due_date")
  priority         Prioritet
  assignedTo       String?   @map("assigned_to")
  caseId           String?   @map("case_id")
  contractId       String?   @map("contract_id")
  note             String?
  adviseDaysBefore Int       @default(3) @map("advise_days_before")
  adviseSentAt     DateTime? @map("advise_sent_at")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  createdBy        String    @map("created_by")
  deletedAt        DateTime? @map("deleted_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  case         Case?        @relation(fields: [caseId], references: [id])
  contract     Contract?    @relation(fields: [contractId], references: [id])

  @@index([organizationId, deletedAt])
  @@index([organizationId, dueDate])
  @@index([dueDate, adviseSentAt])
  // Sprint 5: Dashboard "overskrene frister" — organization_id + due_date + completed_at + deleted_at
  @@index([organizationId, completedAt, dueDate])
  @@map("deadlines")
}

// ==================== DOCUMENTS & FINANCE ====================

model Document {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  companyId      String?          @map("company_id")
  caseId         String?          @map("case_id")
  title          String
  fileUrl        String           @map("file_url")
  fileName       String           @map("file_name")
  fileSizeBytes  Int              @map("file_size_bytes")
  fileType       String           @map("file_type")
  sensitivity    SensitivityLevel @default(STANDARD)
  folderPath     String?          @map("folder_path")
  description    String?
  uploadedAt     DateTime         @default(now()) @map("uploaded_at")
  uploadedBy     String           @map("uploaded_by")
  lastViewedAt   DateTime?        @map("last_viewed_at")
  lastViewedBy   String?          @map("last_viewed_by")
  deletedAt      DateTime?        @map("deleted_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  company      Company?     @relation(fields: [companyId], references: [id])
  case         Case?        @relation(fields: [caseId], references: [id])

  @@index([organizationId, deletedAt])
  @@index([organizationId, companyId, deletedAt])
  @@map("documents")
}

// DEC-008: MetricType, PeriodType, MetricSource enums
// DEC-019: Organization-relation tilføjet
model FinancialMetric {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  companyId      String       @map("company_id")
  metricType     MetricType   @map("metric_type")
  periodType     PeriodType   @map("period_type")
  periodYear     Int          @map("period_year")
  value          Decimal      @db.Decimal(15, 2)
  currency       String       @default("DKK")
  source         MetricSource
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  createdBy      String       @map("created_by")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  company      Company      @relation(fields: [companyId], references: [id])

  @@unique([organizationId, companyId, metricType, periodType, periodYear])
  // Eksisterende index
  @@index([organizationId, companyId])
  // Sprint 5: Dashboard DISTINCT ON query bruger metric_type + period_type + period_year
  // Understøtter "seneste OMSAETNING HELAAR per selskab" uden seq-scan
  @@index([organizationId, companyId, metricType, periodType, periodYear])
  // Sprint 5: Finance-oversigt sorteret på år — organization_id + period_year
  @@index([organizationId, periodYear])
  @@map("financial_metrics")
}

// DEC-019: Organization-relation tilføjet
model TimeEntry {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  caseId         String   @map("case_id")
  userId         String   @map("user_id")
  description    String?
  minutes        Int
  date           DateTime
  billable       Boolean  @default(true)
  hourlyRate     Int?     @map("hourly_rate")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  case         Case         @relation(fields: [caseId], references: [id])

  @@index([organizationId, caseId])
  // Sprint 5: listTimeEntries bruger date-range filter — tilføj date index
  @@index([organizationId, caseId, date])
  @@map("time_entries")
}

// DEC-017: changes (Json?) tilføjet
model AuditLog {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  userId         String            @map("user_id")
  action         String            // VIEW | CREATE | UPDATE | DELETE | DOWNLOAD
  resourceType   String            @map("resource_type")
  resourceId     String            @map("resource_id")
  sensitivity    SensitivityLevel?
  changes        Json?             // DEC-017: feltændringer ved UPDATE
  ipAddress      String?           @map("ip_address")
  createdAt      DateTime          @default(now()) @map("created_at")

  @@index([organizationId, resourceType, resourceId])
  @@index([organizationId, userId])
  @@index([createdAt])
  @@map("audit_log")
}

// ==================== REMINDERS ====================

model Reminder {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  contractId     String    @map("contract_id")
  reminderType   String    @map("reminder_type") // DAYS_90 | DAYS_30 | DAYS_7 | ABSOLUT
  triggerDate    DateTime  @map("trigger_date")
  sentAt         DateTime? @map("sent_at")
  recipientIds   String[]  @map("recipient_ids")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  contract     Contract     @relation(fields: [contractId], references: [id])

  @@index([triggerDate, sentAt])
  @@index([organizationId, contractId])
  @@map("reminders")
}

// ==================== BILLING ====================

model Subscription {
  id                     String    @id @default(uuid())
  organizationId         String    @unique @map("organization_id")
  stripeCustomerId       String    @unique @map("stripe_customer_id")
  stripeSubscriptionId   String    @unique @map("stripe_subscription_id")
  plan                   String    // starter | business | enterprise
  seatCount              Int       @map("seat_count")
  status                 String    // active | trialing | past_due | canceled
  currentPeriodStart     DateTime  @map("current_period_start")
  currentPeriodEnd       DateTime  @map("current_period_end")
  trialEndsAt            DateTime? @map("trial_ends_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([stripeCustomerId])
  @@index([status])
  @@map("subscriptions")
}
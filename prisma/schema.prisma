// ============================================================
// MODELS
// ============================================================

model Organization {
  id             String    @id @default(uuid())
  name           String
  cvr            String?   @unique
  plan           String    @default("starter")
  chainStructure Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      String?   @map("created_by")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  users               User[]
  groups              Group[]
  companies           Company[]
  contracts           Contract[]
  cases               Case[]
  tasks               Task[]
  persons             Person[]
  documents           Document[]
  activities          ActivityLog[]
  userRoleAssignments UserRoleAssignment[]
  financialMetrics    FinancialMetric[]
  notifications       Notification[]

  @@map("organizations")
}

model Group {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  name           String
  description    String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      String?   @map("created_by")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  organization        Organization         @relation(fields: [organizationId], references: [id])
  users               User[]
  userRoleAssignments UserRoleAssignment[]
  companies           Company[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@map("groups")
}

model User {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  groupId        String?   @map("group_id")
  email          String    @unique
  name           String
  avatarUrl      String?   @map("avatar_url")
  microsoftId    String?   @unique @map("microsoft_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      String?   @map("created_by")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  organization        Organization         @relation(fields: [organizationId], references: [id])
  group               Group?               @relation(fields: [groupId], references: [id])
  roleAssignments     UserRoleAssignment[]
  contractsCreated    Contract[]           @relation("ContractCreatedBy")
  casesCreated        Case[]               @relation("CaseCreatedBy")
  tasksAssigned       Task[]               @relation("TaskAssignee")
  tasksCreated        Task[]               @relation("TaskCreatedBy")
  comments            Comment[]
  notifications       Notification[]
  activitiesLogged    ActivityLog[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@map("users")
}

model UserRoleAssignment {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  groupId        String?   @map("group_id")
  userId         String    @map("user_id")
  role           UserRole
  scope          UserScope
  companyIds     String[]  @map("company_ids")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      String?   @map("created_by")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  group        Group?        @relation(fields: [groupId], references: [id])
  user         User          @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, deletedAt])
  @@map("user_role_assignments")
}

model Company {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  groupId        String?     @map("group_id")
  cvr            String?
  name           String
  companyType    CompanyType @map("company_type")
  address        String?
  city           String?
  zip            String?
  country        String      @default("DK")
  email          String?
  phone          String?
  isHolding      Boolean     @default(false) @map("is_holding")
  parentId       String?     @map("parent_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  createdBy      String?     @map("created_by")
  deletedAt      DateTime?   @map("deleted_at")

  // Relations
  organization     Organization      @relation(fields: [organizationId], references: [id])
  group            Group?            @relation(fields: [groupId], references: [id])
  parent           Company?          @relation("CompanyHierarchy", fields: [parentId], references: [id])
  subsidiaries     Company[]         @relation("CompanyHierarchy")
  contracts        Contract[]
  cases            Case[]
  persons          Person[]
  documents        Document[]
  financialMetrics FinancialMetric[]
  ownerships       Ownership[]       @relation("OwnedCompany")
  ownedBy          Ownership[]       @relation("OwnerCompany")

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, parentId])
  @@map("companies")
}

model Ownership {
  id              String        @id @default(uuid())
  organizationId  String        @map("organization_id")
  ownerCompanyId  String        @map("owner_company_id")
  ownedCompanyId  String        @map("owned_company_id")
  ownershipType   OwnershipType @map("ownership_type")
  sharePercentage Decimal       @map("share_percentage") @db.Decimal(5, 2)
  votingRights    Decimal?      @map("voting_rights") @db.Decimal(5, 2)
  validFrom       DateTime      @map("valid_from")
  validTo         DateTime?     @map("valid_to")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  createdBy       String?       @map("created_by")
  deletedAt       DateTime?     @map("deleted_at")

  // Relations
  ownerCompany Company @relation("OwnerCompany", fields: [ownerCompanyId], references: [id])
  ownedCompany Company @relation("OwnedCompany", fields: [ownedCompanyId], references: [id])

  @@index([organizationId])
  @@index([organizationId, ownedCompanyId])
  @@index([organizationId, ownerCompanyId])
  @@map("ownerships")
}

model Person {
  id             String         @id @default(uuid())
  organizationId String         @map("organization_id")
  companyId      String?        @map("company_id")
  firstName      String         @map("first_name")
  lastName       String         @map("last_name")
  email          String?
  phone          String?
  cpr            String?
  address        String?
  city           String?
  zip            String?
  country        String         @default("DK")
  employmentType EmploymentType? @map("employment_type")
  jobTitle       String?        @map("job_title")
  startDate      DateTime?      @map("start_date")
  endDate        DateTime?      @map("end_date")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  createdBy      String?        @map("created_by")
  deletedAt      DateTime?      @map("deleted_at")

  // Relations
  company   Company?   @relation(fields: [companyId], references: [id])
  contracts Contract[]

  @@index([organizationId])
  @@index([organizationId, companyId])
  @@index([organizationId, deletedAt])
  @@map("persons")
}

model Contract {
  id                 String             @id @default(uuid())
  organizationId     String             @map("organization_id")
  companyId          String             @map("company_id")
  personId           String?            @map("person_id")
  systemType         ContractSystemType @map("system_type")
  displayName        String             @map("display_name")
  status             ContractStatus     @default(UDKAST)
  sensitivity        SensitivityLevel   @default(STANDARD)
  deadlineType       DeadlineType       @default(INGEN)
  signedDate         DateTime?          @map("signed_date")
  startDate          DateTime?          @map("start_date")
  endDate            DateTime?          @map("end_date")
  noticePeriodDays   Int?               @map("notice_period_days")
  autoRenew          Boolean            @default(false) @map("auto_renew")
  mustRetainUntil    DateTime?          @map("must_retain_until")
  parentContractId   String?            @map("parent_contract_id")
  triggeredById      String?            @map("triggered_by_id")
  versionSource      VersionSource?     @map("version_source")
  counterpartyName   String?            @map("counterparty_name")
  counterpartyEmail  String?            @map("counterparty_email")
  counterpartyCvr    String?            @map("counterparty_cvr")
  notes              String?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  createdBy          String?            @map("created_by")
  deletedAt          DateTime?          @map("deleted_at")

  // Relations
  organization    Organization     @relation(fields: [organizationId], references: [id])
  company         Company          @relation(fields: [companyId], references: [id])
  person          Person?          @relation(fields: [personId], references: [id])
  createdByUser   User?            @relation("ContractCreatedBy", fields: [createdBy], references: [id])
  parentContract  Contract?        @relation("ContractVersions", fields: [parentContractId], references: [id])
  childContracts  Contract[]       @relation("ContractVersions")
  documents       Document[]
  cases           CaseContract[]
  typeDetails     ContractTypeDetail?
  amendments      ContractAmendment[]
  relations       ContractRelation[] @relation("SourceContract")
  relatedBy       ContractRelation[] @relation("TargetContract")
  retentionRule   RetentionRule?

  @@index([organizationId])
  @@index([organizationId, companyId])
  @@index([organizationId, status])
  @@index([organizationId, deletedAt])
  @@index([organizationId, systemType])
  @@map("contracts")
}

model ContractTypeDetail {
  id                    String     @id @default(uuid())
  contractId            String     @unique @map("contract_id")
  organizationId        String     @map("organization_id")

  // Lease fields
  leaseType             LeaseType? @map("lease_type")
  leaseArea             Decimal?   @map("lease_area") @db.Decimal(10, 2)
  leaseMonthlyRent      Decimal?   @map("lease_monthly_rent") @db.Decimal(12, 2)
  leaseDepositMonths    Int?       @map("lease_deposit_months")
  leaseRegulationClause String?    @map("lease_regulation_clause")

  // Employment fields
  employmentType        EmploymentType? @map("employment_type")
  salary                Decimal?   @map("salary") @db.Decimal(12, 2)
  workingHours          Decimal?   @map("working_hours") @db.Decimal(5, 2)
  nonCompeteMonths      Int?       @map("non_compete_months")
  nonSolicitMonths      Int?       @map("non_solicit_months")
  noticePeriodEmployee  Int?       @map("notice_period_employee")
  noticePeriodEmployer  Int?       @map("notice_period_employer")

  // NDA fields
  ndaType               NdaType?   @map("nda_type")
  ndaDurationMonths     Int?       @map("nda_duration_months")

  // Insurance fields
  insuranceType         InsuranceType? @map("insurance_type")
  insurancePremium      Decimal?   @map("insurance_premium") @db.Decimal(12, 2)
  insuranceCoverage     Decimal?   @map("insurance_coverage") @db.Decimal(15, 2)

  // Meeting fields
  meetingType           MeetingType? @map("meeting_type")
  meetingDate           DateTime?  @map("meeting_date")
  meetingAttendees      String[]   @map("meeting_attendees")
  meetingResolutions    String?    @map("meeting_resolutions")

  // Option fields
  optionType            OptionType? @map("option_type")
  optionShares          Int?       @map("option_shares")
  optionStrikePrice     Decimal?   @map("option_strike_price") @db.Decimal(12, 2)
  optionVestingMonths   Int?       @map("option_vesting_months")
  optionCliffMonths     Int?       @map("option_cliff_months")
  optionExpiryDate      DateTime?  @map("option_expiry_date")

  // Guarantee fields
  guaranteeType         GuaranteeType? @map("guarantee_type")
  guaranteeAmount       Decimal?   @map("guarantee_amount") @db.Decimal(15, 2)
  guaranteeExpiry       DateTime?  @map("guarantee_expiry")

  // Transfer pricing
  tpMethod              TpMethod?  @map("tp_method")
  tpBenchmarkSource     String?    @map("tp_benchmark_source")
  tpMarginMin           Decimal?   @map("tp_margin_min") @db.Decimal(5, 2)
  tpMarginMax           Decimal?   @map("tp_margin_max") @db.Decimal(5, 2)

  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")
  createdBy             String?    @map("created_by")
  deletedAt             DateTime?  @map("deleted_at")

  // Relations
  contract Contract @relation(fields: [contractId], references: [id])

  @@index([organizationId])
  @@map("contract_type_details")
}

model ContractAmendment {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  contractId     String     @map("contract_id")
  changeType     ChangeType @map("change_type")
  versionNumber  Int        @map("version_number")
  title          String
  description    String?
  effectiveDate  DateTime   @map("effective_date")
  documentUrl    String?    @map("document_url")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  createdBy      String?    @map("created_by")
  deletedAt      DateTime?  @map("deleted_at")

  // Relations
  contract Contract @relation(fields: [contractId], references: [id])

  @@index([organizationId])
  @@index([contractId])
  @@map("contract_amendments")
}

model ContractRelation {
  id               String       @id @default(uuid())
  organizationId   String       @map("organization_id")
  sourceContractId String       @map("source_contract_id")
  targetContractId String       @map("target_contract_id")
  relationType     RelationType @map("relation_type")
  notes            String?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  createdBy        String?      @map("created_by")
  deletedAt        DateTime?    @map("deleted_at")

  // Relations
  sourceContract Contract @relation("SourceContract", fields: [sourceContractId], references: [id])
  targetContract Contract @relation("TargetContract", fields: [targetContractId], references: [id])

  @@index([organizationId])
  @@index([sourceContractId])
  @@map("contract_relations")
}

model RetentionRule {
  id                String   @id @default(uuid())
  organizationId    String   @map("organization_id")
  contractId        String   @unique @map("contract_id")
  systemType        ContractSystemType @map("system_type")
  retentionYears    Int      @map("retention_years")
  legalBasis        String?  @map("legal_basis")
  autoCalculated    Boolean  @default(true) @map("auto_calculated")
  calculatedFrom    String?  @map("calculated_from")
  overriddenBy      String?  @map("overridden_by")
  overriddenAt      DateTime? @map("overridden_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  createdBy         String?  @map("created_by")
  deletedAt         DateTime? @map("deleted_at")

  // Relations
  contract Contract @relation(fields: [contractId], references: [id])

  @@index([organizationId])
  @@map("retention_rules")
}

model Case {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  companyId      String     @map("company_id")
  sagsType       SagsType   @map("sags_type")
  sagsSubtype    SagsSubtype? @map("sags_subtype")
  title          String
  description    String?
  status         CaseStatus @default(NY)
  sensitivity    SensitivityLevel @default(STANDARD)
  prioritet      Prioritet  @default(NORMAL)
  assignedTo     String?    @map("assigned_to")
  dueDate        DateTime?  @map("due_date")
  closedAt       DateTime?  @map("closed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  createdBy      String?    @map("created_by")
  deletedAt      DateTime?  @map("deleted_at")

  // Relations
  organization Organization   @relation(fields: [organizationId], references: [id])
  company      Company        @relation(fields: [companyId], references: [id])
  createdByUser User?         @relation("CaseCreatedBy", fields: [createdBy], references: [id])
  contracts    CaseContract[]
  tasks        Task[]
  documents    Document[]
  comments     Comment[]

  @@index([organizationId])
  @@index([organizationId, companyId])
  @@index([organizationId, status])
  @@index([organizationId, deletedAt])
  @@map("cases")
}

model CaseContract {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  caseId         String   @map("case_id")
  contractId     String   @map("contract_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdBy      String?  @map("created_by")

  // Relations
  case     Case     @relation(fields: [caseId], references: [id])
  contract Contract @relation(fields: [contractId], references: [id])

  @@unique([caseId, contractId])
  @@index([organizationId])
  @@map("case_contracts")
}

model Task {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  caseId         String?    @map("case_id")
  companyId      String?    @map("company_id")
  title          String
  description    String?
  status         TaskStatus @default(NY)
  prioritet      Prioritet  @default(NORMAL)
  assignedTo     String?    @map("assigned_to")
  dueDate        DateTime?  @map("due_date")
  completedAt    DateTime?  @map("completed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  createdBy      String?    @map("created_by")
  deletedAt      DateTime?  @map("deleted_at")

  // Relations
  organization  Organization @relation(fields: [organizationId], references: [id])
  case          Case?        @relation(fields: [caseId], references: [id])
  assignee      User?        @relation("TaskAssignee", fields: [assignedTo], references: [id])
  createdByUser User?        @relation("TaskCreatedBy", fields: [createdBy], references: [id])
  comments      Comment[]
  documents     Document[]

  @@index([organizationId])
  @@index([organizationId, caseId])
  @@index([organizationId, deletedAt])
  @@map("tasks")
}

model Document {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  companyId      String?         @map("company_id")
  contractId     String?         @map("contract_id")
  caseId         String?         @map("case_id")
  taskId         String?         @map("task_id")
  category       DocumentCategory
  title          String
  fileUrl        String          @map("file_url")
  fileSize       Int?            @map("file_size")
  mimeType       String?         @map("mime_type")
  sensitivity    SensitivityLevel @default(STANDARD)
  version        Int             @default(1)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  createdBy      String?         @map("created_by")
  deletedAt      DateTime?       @map("deleted_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  company      Company?     @relation(fields: [companyId], references: [id])
  contract     Contract?    @relation(fields: [contractId], references: [id])
  case         Case?        @relation(fields: [caseId], references: [id])
  task         Task?        @relation(fields: [taskId], references: [id])

  @@index([organizationId])
  @@index([organizationId, contractId])
  @@index([organizationId, deletedAt])
  @@map("documents")
}

model Comment {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  caseId         String?  @map("case_id")
  taskId         String?  @map("task_id")
  userId         String   @map("user_id")
  content        String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdBy      String?  @map("created_by")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  user User @relation(fields: [userId], references: [id])
  case Case? @relation(fields: [caseId], references: [id])
  task Task? @relation(fields: [taskId], references: [id])

  @@index([organizationId])
  @@map("comments")
}

model FinancialMetric {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  companyId      String       @map("company_id")
  metricType     MetricType   @map("metric_type")
  periodType     PeriodType   @map("period_type")
  periodYear     Int          @map("period_year")
  periodSubunit  String?      @map("period_subunit")
  value          Decimal      @db.Decimal(18, 2)
  currency       String       @default("DKK")
  source         MetricSource
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  createdBy      String?      @map("created_by")
  deletedAt      DateTime?    @map("deleted_at")

  // Relations
  company Company @relation(fields: [companyId], references: [id])

  @@index([organizationId])
  @@index([organizationId, companyId])
  @@map("financial_metrics")
}

model ActivityLog {
  id             String              @id @default(uuid())
  organizationId String              @map("organization_id")
  userId         String?             @map("user_id")
  entitet        AktivitetsEntitet
  entitetId      String              @map("entitet_id")
  handling       AktivitetsHandling
  metadata       Json?
  ipAddress      String?             @map("ip_address")
  userAgent      String?             @map("user_agent")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  createdBy      String?             @map("created_by")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([organizationId, entitetId])
  @@index([organizationId, userId])
  @@map("activity_logs")
}

model Notification {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  title          String
  body           String
  read           Boolean  @default(false)
  link           String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdBy      String?  @map("created_by")
  deletedAt      DateTime? @map("deleted_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@map("notifications")
}
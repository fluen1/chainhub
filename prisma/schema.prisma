enum AktivitetsEntitet {
  SELSKAB
  KONTRAKT
  SAG
  OPGAVE
  PERSON
  DOKUMENT
}

enum AktivitetsHandling {
  OPRETTET
  OPDATERET
  STATUS_AENDRET
  SLETTET
  TILGAAET
  DOWNLOADET
}

enum Prioritet {
  LAV
  MELLEM
  HOEJ

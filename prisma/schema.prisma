// ==================== CORE MODELS ====================

/// Gruppe/koncern-struktur — bruges til multi-tenant grupperinger
model Group {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  name           String
  description    String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      String?   @map("created_by")
  deletedAt      DateTime? @map("deleted_at")

  organization   Organization @relation(fields: [organizationId], references: [id])
  companies      Company[]
  users          User[]
  roleAssignments UserRoleAssignment[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@map("groups")
}

model Organization {
  id             String    @id @default(uuid())
  name           String
  cvr            String?   @unique
  plan           String    @default("starter")
  chainStructure Boolean   @default(false) @map("chain_structure")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      String?   @map("created_by")
  deletedAt      DateTime? @map("deleted_at")

  companies       Company[]
  users           User[]
  contracts       Contract[]
  persons         Person[]
  cases           Case[]
  documents       Document[]
  alerts          Alert[]
  auditLogs       AuditLog[]
  roleAssignments UserRoleAssignment[]
  financialMetrics FinancialMetric[]
  groups          Group[]

  @@map("organizations")
}

model User {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  groupId        String?   @map("group_id")
  email          String    @unique
  name           String
  avatarUrl      String?   @map("avatar_url")
  microsoftId    String?   @unique @map("microsoft_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      String?   @map("created_by")
  deletedAt      DateTime? @map("deleted_at")

  organization    Organization         @relation(fields: [organizationId], references: [id])
  group           Group?               @relation(fields: [groupId], references: [id])
  roleAssignments UserRoleAssignment[]
  auditLogs       AuditLog[]
  createdContracts Contract[]          @relation("ContractCreatedBy")
  assignedCases   CaseAssignment[]
  createdAlerts   Alert[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([email])
  @@map("users")
}

model UserRoleAssignment {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  groupId        String?   @map("group_id")
  userId         String    @map("user_id")
  role           UserRole
  scope          UserScope @default(ALL)
  companyIds     String[]  @map("company_ids")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      String?   @map("created_by")
  deletedAt      DateTime? @map("deleted_at")

  organization   Organization @relation(fields: [organizationId], references: [id])
  group          Group?       @relation(fields: [groupId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, userId])
  @@index([organizationId, deletedAt])
  @@map("user_role_assignments")
}

model Company {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  groupId        String?   @map("group_id")
  name           String
  cvr            String?
  legalForm      String?   @map("legal_form")
  address        String?
  city           String?
  zipCode        String?   @map("zip_code")
  country        String?   @default("DK")
  foundedDate    DateTime? @map("founded_date")
  dissolvedDate  DateTime? @map("dissolved_date")
  industry       String?
  description    String?
  website        String?
  phone          String?
  email          String?
  chainStructure Boolean   @default(false) @map("chain_structure")
  isHolding      Boolean   @default(false) @map("is_holding")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      String?   @map("created_by")
  deletedAt      DateTime? @map("deleted_at")

  organization     Organization       @relation(fields: [organizationId], references: [id])
  group            Group?             @relation(fields: [groupId], references: [id])
  contracts        Contract[]
  persons          CompanyPerson[]
  ownershipsAs     CompanyOwnership[] @relation("ChildCompany")
  ownershipsOf     CompanyOwnership[] @relation("ParentCompany")
  financialMetrics FinancialMetric[]
  cases            Case[]
  documents        Document[]
  alerts           Alert[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([cvr])
  @@index([organizationId, groupId])
  @@map("companies")
}

model CompanyOwnership {
  id               String        @id @default(uuid())
  organizationId   String        @map("organization_id")
  parentCompanyId  String        @map("parent_company_id")
  childCompanyId   String        @map("child_company_id")
  ownershipPct     Decimal       @map("ownership_pct") @db.Decimal(5, 2)
  votingPct        Decimal?      @map("voting_pct") @db.Decimal(5, 2)
  ownershipType    OwnershipType @default(DIREKTE) @map("ownership_type")
  validFrom        DateTime?     @map("valid_from")
  validTo          DateTime?     @map("valid_to")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  createdBy        String?       @map("created_by")
  deletedAt        DateTime?     @map("deleted_at")

  organization  Organization @relation(fields: [organizationId], references: [id])
  parentCompany Company      @relation("ParentCompany", fields: [parentCompanyId], references: [id])
  childCompany  Company      @relation("ChildCompany", fields: [childCompanyId], references: [id])

  @@index([organizationId])
  @@index([parentCompanyId])
  @@index([childCompanyId])
  @@index([organizationId, deletedAt])
  @@map("company_ownerships")
}

model Person {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  email          String?
  phone          String?
  cpr            String?
  address        String?
  city           String?
  zipCode        String?   @map("zip_code")
  country        String?   @default("DK")
  birthDate      DateTime? @map("birth_date")
  nationality    String?
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      String?   @map("created_by")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization    @relation(fields: [organizationId], references: [id])
  companies    CompanyPerson[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@map("persons")
}

model CompanyPerson {
  id              String         @id @default(uuid())
  organizationId  String         @map("organization_id")
  companyId       String         @map("company_id")
  personId        String         @map("person_id")
  role            String
  title           String?
  employmentType  EmploymentType? @map("employment_type")
  startDate       DateTime?      @map("start_date")
  endDate         DateTime?      @map("end_date")
  anciennityStart DateTime?      @map("anciennity_start")
  contractId      String?        @map("contract_id")
  isPrimary       Boolean        @default(false) @map("is_primary")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  createdBy       String?        @map("created_by")
  deletedAt       DateTime?      @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  company      Company      @relation(fields: [companyId], references: [id])
  person       Person       @relation(fields: [personId], references: [id])
  contract     Contract?    @relation(fields: [contractId], references: [id])

  @@index([organizationId])
  @@index([companyId])
  @@index([personId])
  @@index([organizationId, deletedAt])
  @@map("company_persons")
}

// ==================== CONTRACTS ====================

model Contract {
  id                 String             @id @default(uuid())
  organizationId     String             @map("organization_id")
  companyId          String             @map("company_id")
  systemType         ContractSystemType @map("system_type")
  displayName        String             @map("display_name")
  status             ContractStatus     @default(UDKAST)
  sensitivity        SensitivityLevel   @default(STANDARD)
  deadlineType       DeadlineType       @default(INGEN) @map("deadline_type")
  parentContractId   String?            @map("parent_contract_id")
  triggeredById      String?            @map("triggered_by_id")
  versionSource      VersionSource      @default(INTERNT) @map("version_source")
  mustRetainUntil    DateTime?          @map("must_retain_until")
  signedDate         DateTime?          @map("signed_date")
  effectiveDate      DateTime?          @map("effective_date")
  expiryDate         DateTime?          @map("expiry_date")
  terminationDate    DateTime?          @map("termination_date")
  noticePeriodDays   Int?               @map("notice_period_days")
  autoRenewal        Boolean            @default(false) @map("auto_renewal")
  counterpartyName   String?            @map("counterparty_name")
  counterpartyCvr    String?            @map("counterparty_cvr")
  counterpartyEmail  String?            @map("counterparty_email")
  totalValue         Decimal?           @map("total_value") @db.Decimal(15, 2)
  currency           String?            @default("DKK")
  notes              String?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  createdBy          String?            @map("created_by")
  deletedAt          DateTime?          @map("deleted_at")

  organization    Organization      @relation(fields: [organizationId], references: [id])
  company         Company           @relation(fields: [companyId], references: [id])
  createdByUser   User?             @relation("ContractCreatedBy", fields: [createdBy], references: [id])
  parentContract  Contract?         @relation("ContractVersions", fields: [parentContractId], references: [id])
  childContracts  Contract[]        @relation("ContractVersions")
  triggeredBy     Contract?         @relation("ContractTriggers", fields: [triggeredById], references: [id])
  triggeredContracts Contract[]     @relation("ContractTriggers")
  documents       Document[]
  alerts          Alert[]
  relations       ContractRelation[] @relation("SourceContract")
  relatedBy       ContractRelation[] @relation("TargetContract")
  companyPersons  CompanyPerson[]
  contractDetails ContractDetails?

  @@index([organizationId])
  @@index([companyId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, status])
  @@index([organizationId, systemType])
  @@index([expiryDate])
  @@index([organizationId, companyId, deletedAt])
  @@map("contracts")
}

model ContractDetails {
  id         String   @id @default(uuid())
  contractId String   @unique @map("contract_id")

  // Lease fields
  leaseType        LeaseType?  @map("lease_type")
  monthlyRent      Decimal?    @map("monthly_rent") @db.Decimal(15, 2)
  depositMonths    Int?        @map("deposit_months")
  prepaidMonths    Int?        @map("prepaid_months")
  sqm              Int?
  indexClause      Boolean?    @map("index_clause")

  // NDA fields
  ndaType          NdaType?   @map("nda_type")
  confidentialityPeriodYears Int? @map("confidentiality_period_years")

  // Insurance fields
  insuranceType    InsuranceType? @map("insurance_type")
  coverageAmount   Decimal?       @map("coverage_amount") @db.Decimal(15, 2)
  premium          Decimal?       @db.Decimal(15, 2)

  // Meeting fields
  meetingType      MeetingType? @map("meeting_type")
  meetingDate      DateTime?    @map("meeting_date")
  meetingLocation  String?      @map("meeting_location")

  // Option fields
  optionType       OptionType?  @map("option_type")
  strikePrice      Decimal?     @map("strike_price") @db.Decimal(15, 2)
  exerciseDeadline DateTime?    @map("exercise_deadline")

  // Guarantee fields
  guaranteeType    GuaranteeType? @map("guarantee_type")
  guaranteeAmount  Decimal?       @map("guarantee_amount") @db.Decimal(15, 2)

  // Employment fields
  employmentType   EmploymentType? @map("employment_type")
  salary           Decimal?        @db.Decimal(15, 2)
  pensionPct       Decimal?        @map("pension_pct") @db.Decimal(5, 2)
  trialPeriodDays  Int?            @map("trial_period_days")

  // Transfer pricing fields
  tpMethod         TpMethod?  @map("tp_method")
  armslengthRate   Decimal?   @map("armslength_rate") @db.Decimal(8, 4)

  // Change type (for allonge/version)
  changeType       ChangeType? @map("change_type")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contract Contract @relation(fields: [contractId], references: [id])

  @@map("contract_details")
}

model ContractRelation {
  id               String       @id @default(uuid())
  organizationId   String       @map("organization_id")
  sourceContractId String       @map("source_contract_id")
  targetContractId String       @map("target_contract_id")
  relationType     RelationType @map("relation_type")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  createdBy        String?      @map("created_by")

  organization   Organization @relation(fields: [organizationId], references: [id])
  sourceContract Contract     @relation("SourceContract", fields: [sourceContractId], references: [id])
  targetContract Contract     @relation("TargetContract", fields: [targetContractId], references: [id])

  @@index([organizationId])
  @@index([sourceContractId])
  @@index([targetContractId])
  @@map("contract_relations")
}

// ==================== CASES ====================

model Case {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  companyId      String      @map("company_id")
  title          String
  description    String?
  sagsType       SagsType    @map("sags_type")
  sagsSubtype    SagsSubtype? @map("sags_subtype")
  status         CaseStatus  @default(NY)
  sensitivity    SensitivityLevel @default(STANDARD)
  prioritet      Prioritet   @default(NORMAL)
  deadlineDate   DateTime?   @map("deadline_date")
  closedAt       DateTime?   @map("closed_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  createdBy      String?     @map("created_by")
  deletedAt      DateTime?   @map("deleted_at")

  organization Organization    @relation(fields: [organizationId], references: [id])
  company      Company         @relation(fields: [companyId], references: [id])
  assignments  CaseAssignment[]
  documents    Document[]
  tasks        Task[]
  alerts       Alert[]

  @@index([organizationId])
  @@index([companyId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, status])
  @@map("cases")
}

model CaseAssignment {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  caseId         String   @map("case_id")
  userId         String   @map("user_id")
  role           String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdBy      String?  @map("created_by")

  organization Organization @relation(fields: [organizationId], references: [id])
  case         Case         @relation(fields: [caseId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([caseId])
  @@index([userId])
  @@map("case_assignments")
}

model Task {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  caseId         String     @map("case_id")
  title          String
  description    String?
  status         TaskStatus @default(NY)
  prioritet      Prioritet  @default(NORMAL)
  assignedTo     String?    @map("assigned_to")
  dueDate        DateTime?  @map("due_date")
  completedAt    DateTime?  @map("completed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  createdBy      String?    @map("created_by")
  deletedAt      DateTime?  @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  case         Case         @relation(fields: [caseId], references: [id])

  @@index([organizationId])
  @@index([caseId])
  @@index([organizationId, deletedAt])
  @@map("tasks")
}

// ==================== DOCUMENTS ====================

model Document {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  companyId      String?          @map("company_id")
  contractId     String?          @map("contract_id")
  caseId         String?          @map("case_id")
  title          String
  description    String?
  fileUrl        String?          @map("file_url")
  fileSize       Int?             @map("file_size")
  mimeType       String?          @map("mime_type")
  sensitivity    SensitivityLevel @default(STANDARD)
  version        Int              @default(1)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  createdBy      String?          @map("created_by")
  deletedAt      DateTime?        @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  company      Company?     @relation(fields: [companyId], references: [id])
  contract     Contract?    @relation(fields: [contractId], references: [id])
  case         Case?        @relation(fields: [caseId], references: [id])

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([contractId])
  @@index([caseId])
  @@map("documents")
}

// ==================== FINANCIAL METRICS ====================

model FinancialMetric {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  companyId      String       @map("company_id")
  metricType     MetricType   @map("metric_type")
  value          Decimal      @db.Decimal(20, 2)
  currency       String       @default("DKK")
  periodType     PeriodType   @map("period_type")
  periodYear     Int          @map("period_year")
  periodNumber   Int?         @map("period_number")
  source         MetricSource @default(UREVIDERET)
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  createdBy      String?      @map("created_by")
  deletedAt      DateTime?    @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  company      Company      @relation(fields: [companyId], references: [id])

  @@index([organizationId])
  @@index([companyId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, companyId, periodYear])
  @@map("financial_metrics")
}

// ==================== ALERTS ====================

model Alert {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  companyId      String?     @map("company_id")
  contractId     String?     @map("contract_id")
  caseId         String?     @map("case_id")
  alertType      AlertType   @map("alert_type")
  status         AlertStatus @default(AKTIV)
  title          String
  description    String?
  dueDate        DateTime?   @map("due_date")
  snoozedUntil   DateTime?   @map("snoozed_until")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  createdBy      String?     @map("created_by")
  deletedAt      DateTime?   @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  company      Company?     @relation(fields: [companyId], references: [id])
  contract     Contract?    @relation(fields: [contractId], references: [id])
  case         Case?        @relation(fields: [caseId], references: [id])
  createdByUser User?       @relation(fields: [createdBy], references: [id])

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, status])
  @@index([dueDate])
  @@map("alerts")
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  userId         String?     @map("user_id")
  action         AuditAction
  entityType     String      @map("entity_type")
  entityId       String      @map("entity_id")
  oldValues      Json?       @map("old_values")
  newValues      Json?       @map("new_values")
  ipAddress      String?     @map("ip_address")
  userAgent      String?     @map("user_agent")
  createdAt      DateTime    @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([organizationId, createdAt])
  @@map("audit_logs")
}


{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["fra1"],
  "headers": [
    {
      "source": "/api/health",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store" }]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/extract-pending",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/portfolio-scan",
      "schedule": "5 6 * * *"
    }
  ]
}

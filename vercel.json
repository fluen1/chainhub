{
  "crons": [
    {
      "path": "/api/cron/task-digest",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/contract-expiry",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/subscription-sync",
      "schedule": "0 */6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/webhooks/stripe",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/api/health",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "chainhub.dk"
        }
      ],
      "destination": "https://www.chainhub.dk/:path*",
      "permanent": true
    }
  ]
}
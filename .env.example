# ==================== DATABASE ====================
DATABASE_URL="postgresql://user:password@localhost:5432/chainhub"

# ==================== AUTH ====================
NEXTAUTH_SECRET="din-hemmelige-nøgle-her"
NEXTAUTH_URL="http://localhost:3000"

# Microsoft Azure AD (valgfri — til SSO)
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# ==================== CLOUDFLARE R2 STORAGE ====================
# Kræves for fil-upload og download
# Opret en R2-bucket i Cloudflare-dashboardet
# Opret API-token med læse- og skriveadgang til R2

# Navnet på din R2-bucket
R2_BUCKET_NAME="chainhub-documents"

# Din Cloudflare account ID (findes i dashboardet)
R2_ACCOUNT_ID=""

# R2 API-nøgler (opret under Cloudflare > R2 > Manage R2 API tokens)
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# ==================== STRIPE ====================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ==================== APP ====================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
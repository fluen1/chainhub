# ============================================
# ChainHub — Environment Variables
# ============================================
# Kopiér til .env.local og udfyld værdier

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/chainhub?schema=public"

# NextAuth
NEXTAUTH_SECRET="generer-med-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Microsoft OAuth (Azure AD)
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID=""

# Stripe (Sprint 6)
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

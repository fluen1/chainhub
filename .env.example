# ============================================================
# ChainHub — Environment Variables
# ============================================================
# Kopiér denne fil til .env.local til lokal udvikling.
# Sæt alle produktionsvariabler i Vercel Dashboard.
# Valideres automatisk af validate-env.ts ved startup og CI.
# ============================================================

# ------------------------------------------------------------
# Database (Supabase PostgreSQL)
# ------------------------------------------------------------
DATABASE_URL="postgresql://username:password@db.xxx.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"

# ------------------------------------------------------------
# NextAuth
# ------------------------------------------------------------
# ⚠️  KRITISK: NEXTAUTH_SECRET skal være MINIMUM 32 tegn.
#     Generér med: openssl rand -base64 32
#     Kortere secrets afvises og bryder al authentication.
NEXTAUTH_URL="http://localhost:3000"
# Produktion: NEXTAUTH_URL="https://www.chainhub.dk"
NEXTAUTH_SECRET="generer-med-openssl-rand-base64-32-minimum-32-tegn!!"

# ------------------------------------------------------------
# Microsoft OAuth (Azure AD / Entra ID)
# ------------------------------------------------------------
MICROSOFT_CLIENT_ID="dit-azure-application-client-id"
MICROSOFT_CLIENT_SECRET="dit-azure-client-secret-value"
MICROSOFT_TENANT_ID="dit-azure-directory-tenant-id"

# ------------------------------------------------------------
# Cloudflare R2 Storage (fil-upload til kontrakter/dokumenter)
# ------------------------------------------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ------------------------------------------------------------
# Stripe Billing
# ------------------------------------------------------------
STRIPE_SECRET_KEY=""

# ⚠️  KRITISK: Webhook URL i Stripe Dashboard SKAL have www-prefix.
#
#     ✅ KORREKT:  https://www.chainhub.dk/api/webhooks/stripe
#     ❌ FORKERT:  https://chainhub.dk/api/webhooks/stripe
#
#     Uden www-prefix: Stripe modtager HTTP 301 redirect og opgiver.
#     Webhooks fejler STILLE — ingen kode kører, ingen fejlbesked.
#
# ⚠️  KRITISK: Kopiér webhook secret præcist — ingen trailing newlines.
#     Trailing whitespace giver stille signaturfejl.
#     Koden trimmer automatisk: process.env.STRIPE_WEBHOOK_SECRET?.trim()
STRIPE_WEBHOOK_SECRET=""

STRIPE_STARTER_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""
STRIPE_ENTERPRISE_PRICE_ID=""

# ------------------------------------------------------------
# App URL
# ------------------------------------------------------------
# Bruges til Stripe success/cancel redirects og absolutte URLs.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Produktion: NEXT_PUBLIC_APP_URL="https://www.chainhub.dk"

# ------------------------------------------------------------
# Monitoring: Sentry Error Tracking
# ------------------------------------------------------------
# Opret projekt på sentry.io og kopiér DSN herfra:
# Sentry Dashboard → Project → Settings → Client Keys (DSN)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG="chainhub"
SENTRY_PROJECT="chainhub-prod"
# Auth token til source maps upload i CI (Sentry → Settings → Auth Tokens)
SENTRY_AUTH_TOKEN=""

# ------------------------------------------------------------
# Monitoring: Vercel Analytics
# ------------------------------------------------------------
# Automatisk sat af Vercel i produktionsmiljø.
# Til lokal test: hent fra Vercel Dashboard → Project → Analytics.
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""

# ------------------------------------------------------------
# Alerting: Email ved payment_failed webhook
# ------------------------------------------------------------
# Modtager-email til payment_failed alerts
ALERT_EMAIL_TO="ops@chainhub.dk"
# Resend API key til transaktionel email (https://resend.com)
RESEND_API_KEY=""

# ------------------------------------------------------------
# Rate Limiting (Upstash Redis)
# ------------------------------------------------------------
# Kræves til rate limiting i middleware (PENTEST-005).
# Opret gratis Redis database på upstash.com.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ------------------------------------------------------------
# E2E Test (KUN til testmiljø — aldrig i produktion)
# ------------------------------------------------------------
E2E_RUN_AUTH_TESTS=""
E2E_RUN_CONTRACT_TESTS=""
E2E_RUN_TENANT_TESTS=""
E2E_GROUP_OWNER_EMAIL=""
E2E_GROUP_OWNER_PASSWORD=""
E2E_GROUP_LEGAL_EMAIL=""
E2E_GROUP_LEGAL_PASSWORD=""
E2E_COMPANY_MANAGER_EMAIL=""
E2E_COMPANY_MANAGER_PASSWORD=""
E2E_TEST_COMPANY_ID=""
E2E_TEST_CONTRACT_ID=""
E2E_STRICT_CONTRACT_ID=""
E2E_TENANT_A_EMAIL=""
E2E_TENANT_A_PASSWORD=""
E2E_TENANT_B_COMPANY_ID=""
E2E_TENANT_B_CONTRACT_ID=""
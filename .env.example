# Database
DATABASE_URL="postgresql://user:password@localhost:5432/chainhub"

# NextAuth
NEXTAUTH_SECRET="din-hemlige-nextauth-secret-min-32-tegn"
NEXTAUTH_URL="http://localhost:3000"

# Microsoft OAuth (Azure AD)
MICROSOFT_CLIENT_ID="dit-azure-app-client-id"
MICROSOFT_CLIENT_SECRET="dit-azure-app-client-secret"
MICROSOFT_TENANT_ID="dit-azure-tenant-id"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudflare R2 (fil-upload)
# Se: https://developers.cloudflare.com/r2/
R2_BUCKET_NAME="chainhub-files"
R2_ACCOUNT_ID="dit-cloudflare-account-id"
R2_ACCESS_KEY_ID="din-r2-access-key-id"
R2_SECRET_ACCESS_KEY="din-r2-secret-access-key"
# Valgfri: Offentlig URL til R2-bucket (kun til offentlige filer)
R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"
# ChainHub — Environment Variables
# Copy this file to .env.local and fill in values
# Se docs/ops/RUNBOOK.md for detaljerede instruktioner

# ────────────────────────────────────────────────────
# DATABASE (Supabase PostgreSQL) — BEGGE er påkrævet
# ────────────────────────────────────────────────────
# Transaction Pooler URL (port 6543, bruges af applikationen)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct Connection URL (port 5432, bruges af prisma migrate dev)
DIRECT_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ────────────────────────────────────────────────────
# AUTH — PÅKRÆVET
# ────────────────────────────────────────────────────
# Minimum 32 tegn — generer med: openssl rand -base64 32
NEXTAUTH_SECRET=ERSTAT-MED-MINIMUM-32-TEGNS-HEMMELIGHED

# URL til din applikation (ingen trailing slash).
# VIGTIGT: Denne værdi SKAL matche den faktiske port Next.js dev-serveren lytter på.
# Hvis port 3000 er optaget starter Next.js automatisk på 3001, 3002 osv.
# Symptom på forkert port: login-redirect fejler, callbacks returnerer 401/404.
# Eksempel: hvis `npm run dev` printer "ready on http://localhost:3001", sæt:
#   NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3000

# ────────────────────────────────────────────────────
# GOOGLE OAUTH (valgfrit — opret i Google Cloud Console → APIs & Services → Credentials)
# ────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ────────────────────────────────────────────────────
# MICROSOFT OAUTH (valgfrit — SSO og Graph API)
# ────────────────────────────────────────────────────
# MICROSOFT_CLIENT_ID=00000000-0000-0000-0000-000000000000
# MICROSOFT_CLIENT_SECRET=

# Vercel sætter automatisk VERCEL_URL — bruges som fallback for NEXTAUTH_URL i preview deploys.
# Sæt ikke denne manuelt.
# VERCEL_URL=

# ────────────────────────────────────────────────────
# STRIPE BILLING (valgfrit — ikke krævet til dev)
# ────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# VIGTIGT: Webhook URL skal bruge www-prefix: https://www.chainhub.dk/api/webhooks/stripe

# ────────────────────────────────────────────────────
# APP
# ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ────────────────────────────────────────────────────
# EMAIL DIGEST (Resend)
# ────────────────────────────────────────────────────
# RESEND_API_KEY=re_...
# DIGEST_FROM_EMAIL=ChainHub <noreply@chainhub.dk>
# DIGEST_CRON_SECRET=your-secret-here

# ────────────────────────────────────────────────────
# AI / LLM configuration (OpenAI)
# ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
# Valgfri: brug eu.api.openai.com/v1 hvis projektet er pinned til EU-region
# OPENAI_BASE_URL=https://eu.api.openai.com/v1
AI_EXTRACTION_ENABLED=false
AI_LOG_LEVEL=info

# ────────────────────────────────────────────────────
# E2E TESTS (lokal Docker PG på port 5433)
# ────────────────────────────────────────────────────
# Sæt KUN i .env.local — Playwright bruger denne i stedet for DATABASE_URL
# Start med: docker compose up -d postgres-e2e && npm run db:e2e:reset
# E2E_DATABASE_URL=postgresql://chainhub:chainhub@localhost:5433/chainhub_e2e

# ────────────────────────────────────────────────────
# STORAGE (local filesystem eller Cloudflare R2)
# ────────────────────────────────────────────────────
# Storage provider: 'local' (filesystem, default) eller 'r2' (Cloudflare R2)
STORAGE_PROVIDER=local

# R2 credentials (kun påkrævet hvis STORAGE_PROVIDER=r2)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# ────────────────────────────────────────────────────
# OBSERVABILITY (valgfrit — kraftigt anbefalet i produktion)
# ────────────────────────────────────────────────────
# Logging-niveau for struktureret Pino-log
# Niveauer: trace, debug, info, warn, error, fatal
LOG_LEVEL=debug

# Sentry error tracking (uden DSN er Sentry fuldt deaktiveret)
# SENTRY_DSN=https://...@...ingest.sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@...ingest.sentry.io/...
# SENTRY_ORG=chainhub
# SENTRY_PROJECT=chainhub-app

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/chainhub_dev?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="din-hemmelige-nextauth-secret-minimum-32-tegn"

# Microsoft OAuth (Azure AD)
MICROSOFT_CLIENT_ID="dit-azure-client-id"
MICROSOFT_CLIENT_SECRET="dit-azure-client-secret"
MICROSOFT_TENANT_ID="dit-azure-tenant-id"

# Cloudflare R2 Storage (valgfrit — fil-upload)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ============================================================
# Stripe Billing
# ============================================================
STRIPE_SECRET_KEY=""
# ⚠️  KRITISK: Webhook URL SKAL have www-prefix i Stripe Dashboard:
#     KORREKT:  https://www.chainhub.dk/api/webhooks/stripe
#     FORKERT:  https://chainhub.dk/api/webhooks/stripe
#
# ⚠️  KRITISK: Kopiér webhook secret præcis — ingen trailing newlines.
#     Trailing whitespace/newlines giver stille fejl (signaturen valideres aldrig).
#     Valideres automatisk via: process.env.STRIPE_WEBHOOK_SECRET?.trim()
STRIPE_WEBHOOK_SECRET=""
STRIPE_STARTER_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""
STRIPE_ENTERPRISE_PRICE_ID=""

# App URL (bruges bl.a. til Stripe success/cancel redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"


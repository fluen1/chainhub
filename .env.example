# ChainHub — Environment Variables
# Copy to .env.local and fill in values

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Auth
NEXTAUTH_SECRET=minimum-32-tegn-lang-hemmelighed
NEXTAUTH_URL=http://localhost:3000

# Microsoft OAuth (optional)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# Stripe (optional for dev)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

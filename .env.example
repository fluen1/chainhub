# ============================================================
# ChainHub — Environment Variables
# ============================================================
# Kopiér denne fil til .env.local til lokal udvikling.
# Sæt alle produktionsvariabler i Vercel Dashboard.
# Valideres automatisk af validate-env.ts ved startup og CI.
#
# KONVENTIONER:
#   - SCREAMING_SNAKE_CASE for alle variabler
#   - NEXT_PUBLIC_ prefix for klient-eksponerede variabler
#   - Aldrig sæt rigtige credentials i denne fil
# ============================================================

# ------------------------------------------------------------
# Database (Supabase PostgreSQL)
# ------------------------------------------------------------
# Hent fra Supabase Dashboard → Project → Settings → Database → Connection String
# Brug "Transaction" pooler-URL (port 6543) med pgbouncer=true
DATABASE_URL="postgresql://username:password@db.xxx.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"

# ------------------------------------------------------------
# NextAuth
# ------------------------------------------------------------
# ⚠️  KRITISK: NEXTAUTH_SECRET skal være MINIMUM 32 tegn.
#     Generér med: openssl rand -base64 32
#     Kortere secrets afvises af NextAuth og bryder AL authentication.
#     Alle eksisterende sessioner invalideres ved rotation.
#
# Rotationsprocedure:
#   1. openssl rand -base64 32
#   2. Opdatér NEXTAUTH_SECRET i Vercel Dashboard
#   3. Redeploy UDEN build cache
#   4. Test login i incognito-vindue
#   5. Alle brugere skal logge ind igen — kommunikér i advance
#
# Se docs/ops/RUNBOOK.md §7.1 for fuld rotationsprocedure.
NEXTAUTH_URL="http://localhost:3000"
# Produktion: NEXTAUTH_URL="https://www.chainhub.dk"
NEXTAUTH_SECRET="generer-med-openssl-rand-base64-32-minimum-32-tegn!!"

# ------------------------------------------------------------
# Microsoft OAuth (Azure AD / Entra ID)
# ------------------------------------------------------------
# Hent fra Azure Portal → App registrations → ChainHub → Overview
MICROSOFT_CLIENT_ID="dit-azure-application-client-id"
# Hent fra Azure Portal → App registrations → ChainHub → Certificates & secrets
# VIGTIGT: Kopiér "Value" kolonnen — ikke "Secret ID"
# Client secrets udløber — sæt påmindelse 30 dage inden udløb
MICROSOFT_CLIENT_SECRET="dit-azure-client-secret-value"
# Hent fra Azure Portal → Azure Active Directory → Overview → Tenant ID
MICROSOFT_TENANT_ID="dit-azure-directory-tenant-id"

# ------------------------------------------------------------
# Cloudflare R2 Storage (fil-upload til kontrakter/dokumenter)
# ------------------------------------------------------------
# Hent fra Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="chainhub-documents"
R2_PUBLIC_URL=""

# ------------------------------------------------------------
# Stripe Billing
# ------------------------------------------------------------
# Hent fra Stripe Dashboard → Developers → API keys
# Produktion: brug "sk_live_..." nøgle
# Test: brug "sk_test_..." nøgle
STRIPE_SECRET_KEY=""

# ⚠️  KRITISK: Stripe Webhook URL SKAL have www-prefix.
#
#     Stripe sender POST-requests. Hvis chainhub.dk redirecter til
#     www.chainhub.dk via HTTP 301, følger Stripe IKKE redirectet.
#     Webhooks fejler STILLE — ingen kode kører, ingen fejlbesked.
#
#     Konfigurér i Stripe Dashboard → Developers → Webhooks → Add endpoint:
#     ✅ KORREKT:  https://www.chainhub.dk/api/webhooks/stripe
#     ❌ FORKERT:  https://chainhub.dk/api/webhooks/stripe
#
#     Webhook events der skal konfigureres:
#       payment_intent.succeeded
#       payment_intent.payment_failed
#       customer.subscription.created
#       customer.subscription.updated
#       customer.subscription.deleted
#       invoice.payment_succeeded
#       invoice.payment_failed
#
# ⚠️  KRITISK: Ingen trailing whitespace i webhook secret.
#     Copy-paste fra Stripe Dashboard kan tilføje newlines.
#     Koden trimmer automatisk: process.env.STRIPE_WEBHOOK_SECRET?.trim()
#     Men sørg for at Vercel-værdien ikke har trailing chars.
#
# Se docs/ops/RUNBOOK.md §2 og §4 for fejlhåndtering.
STRIPE_WEBHOOK_SECRET=""

# Stripe pris-IDs (hent fra Stripe Dashboard → Products)
STRIPE_STARTER_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""
STRIPE_ENTERPRISE_PRICE_ID=""

# ------------------------------------------------------------
# App URL
# ------------------------------------------------------------
# Bruges til Stripe success/cancel redirects og absolutte URLs i emails.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Produktion: NEXT_PUBLIC_APP_URL="https://www.chainhub.dk"

# ------------------------------------------------------------
# Monitoring: Sentry Error Tracking
# ------------------------------------------------------------
# Opret projekt på sentry.io og kopiér DSN herfra:
# Sentry Dashboard → Project → Settings → Client Keys (DSN)
#
# SENTRY_DSN bruges serverside (Node.js runtime)
# NEXT_PUBLIC_SENTRY_DSN bruges klientside (browser)
# Begge kan pege på samme Sentry-projekt/DSN.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Organisation og projekt til Sentry CLI (source maps upload i CI)
SENTRY_ORG="chainhub"
SENTRY_PROJECT="chainhub-prod"

# Auth token til source maps upload i CI/CD pipeline
# Sentry Dashboard → Settings → Auth Tokens → Create New Token
# Kræver scopes: project:write, org:read
SENTRY_AUTH_TOKEN=""

# ------------------------------------------------------------
# Monitoring: Vercel Analytics
# ------------------------------------------------------------
# Aktiveres automatisk i Vercel-miljø via @vercel/analytics pakken.
# Til lokal test: hent ID fra Vercel Dashboard → Project → Analytics.
# I produktion sættes denne automatisk af Vercel.
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""

# ------------------------------------------------------------
# Alerting: Email ved payment_failed webhook event
# ------------------------------------------------------------
# Email-adresse der modtager alert når Stripe payment fejler.
# Se docs/ops/RUNBOOK.md §9.3 for implementeringsdetaljer.
ALERT_EMAIL_TO="ops@chainhub.dk"

# Resend API key til transaktionel email (https://resend.com)
# Kræves til payment_failed alerts og cron-job notifikationer.
# Hent fra Resend Dashboard → API Keys
RESEND_API_KEY=""

# ------------------------------------------------------------
# Rate Limiting (Upstash Redis)
# ------------------------------------------------------------
# Kræves til rate limiting i middleware (se PENTEST-005 i PENTEST-REPORT.md).
# Opret gratis Redis database på https://console.upstash.com
# Hent credentials fra: Database → REST API
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ------------------------------------------------------------
# Cron Job Sikkerhed
# ------------------------------------------------------------
# Secret til at verificere at cron-endpoints kun kaldes af Vercel.
# Generér med: openssl rand -hex 32
# Sæt samme værdi i Vercel Dashboard.
CRON_SECRET=""

# ------------------------------------------------------------
# E2E Test (KUN til testmiljø — aldrig i produktion)
# ------------------------------------------------------------
# Disse variabler bruges udelukkende af Playwright E2E tests.
# Sæt aldrig rigtige bruger-credentials i denne fil.
E2E_RUN_AUTH_TESTS=""
E2E_RUN_CONTRACT_TESTS=""
E2E_RUN_TENANT_TESTS=""

# Test-bruger credentials (brug dedikerede test-konti)
E2E_GROUP_OWNER_EMAIL=""
E2E_GROUP_OWNER_PASSWORD=""
E2E_GROUP_LEGAL_EMAIL=""
E2E_GROUP_LEGAL_PASSWORD=""
E2E_COMPANY_MANAGER_EMAIL=""
E2E_COMPANY_MANAGER_PASSWORD=""

# Test-data IDs (opret dedikerede test-ressourcer)
E2E_TEST_COMPANY_ID=""
E2E_TEST_CONTRACT_ID=""
E2E_STRICT_CONTRACT_ID=""

# Tenant isolation test-data
E2E_TENANT_A_EMAIL=""
E2E_TENANT_A_PASSWORD=""
E2E_TENANT_B_COMPANY_ID=""
E2E_TENANT_B_CONTRACT_ID=""